FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build:backend

FROM node:20-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000

# Fonts for chart rendering (sharp → librsvg needs fontconfig + TTFs).
# Noto covers Latin, Cyrillic, Greek, etc.; Noto-CJK covers Chinese/Japanese/Korean; DejaVu as fallback.
# Sharp's prebuilt libvips bundles its own librsvg/fontconfig — point it at Alpine's config + font dirs.
ENV FONTCONFIG_PATH=/etc/fonts
ENV FONTCONFIG_FILE=/etc/fonts/fonts.conf
RUN apk add --no-cache \
      fontconfig \
      ttf-dejavu \
      font-noto \
      font-noto-cjk \
      font-noto-emoji \
    && fc-cache -f \
    && fc-list | head -n 5

COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=build /app/dist ./dist

# Persist MCP render_chart output: docker run -v $(pwd)/charts-public:/app/charts-public ...

EXPOSE 3000
CMD ["node", "dist/standalone-http.js"]
