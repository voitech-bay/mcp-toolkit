# Enrichment queue worker (`npx tsx src/workers/enrichment-worker.ts`)
# The worker loads `dotenv/config` (`.env` in the project root). Copy these values
# into `.env`, or use them as a checklist when configuring a dedicated worker host.

# Required: same project as the app; worker must use the service role (not anon).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Unique id for this process (logs + stored on claimed queue rows as `claimed_by` and on
# each `enrichment_agent_runs.meta.worker_name` / `input.worker_name`). Use one value per replica.
# If unset, defaults to enrichment-worker-<hostname>-<pid>.
ENRICHMENT_WORKER_NAME=enrichment-worker-local-1

# Optional: POST heartbeats to the main API so the UI can show this worker (same origin as the app in dev).
# WORKER_API_BASE_URL=http://127.0.0.1:3001
# WORKER_HEARTBEAT_INTERVAL_MS=10000
# Optional shared secret (must match WORKER_HEARTBEAT_SECRET on the API if set)
# WORKER_HEARTBEAT_SECRET=

# Optional: listen for GET /status JSON on this port (debug / load balancers)
# ENRICHMENT_WORKER_HTTP_PORT=0

# Optional tuning (defaults in parentheses)
# ENRICHMENT_MAX_PARALLEL=5
# ENRICHMENT_CLAIM_LIMIT=10
# ENRICHMENT_POLL_INTERVAL_MS=2000
# ENRICHMENT_LOCK_MINUTES=15
