{
  "name": "mcp-toolkit",
  "version": "0.1.0",
  "description": "MCP server: Supabase messages + Company enrichment (Streamable HTTP / SSE for Vercel)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cd frontend && npm ci && npm run build",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "dev": "tsx src/stdio.ts",
    "dev:http": "tsx src/standalone-http.ts",
    "dev:api": "tsx src/api-server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "node dist/api-server.js",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.0",
    "lucide-vue-next": "^0.576.0",
    "openai": "^6.32.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
