{
  "name": "mcp-toolkit",
  "version": "0.1.0",
  "description": "MCP server: Supabase messages + Company enrichment (Streamable HTTP / SSE for Vercel)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cd frontend && npm ci && npm run build",
    "build:backend": "tsc",
    "build:worker": "tsc -p tsconfig.worker.json",
    "build:worker:clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.worker.json",
    "build:frontend": "cd frontend && npm run build",
    "build:client-frontend": "cd client_frontend && npm run build",
    "dev": "tsx src/stdio.ts",
    "dev:worker": "tsx src/workers/enrichment-worker.ts",
    "dev:http": "tsx src/api-server.ts",
    "dev:api": "tsx src/api-server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:client-frontend": "cd client_frontend && npm run dev",
    "start:client-frontend": "cd client_frontend && npm run preview",
    "dev:enrichment-worker": "tsx src/workers/enrichment-worker.ts",
    "start:worker": "node dist/workers/enrichment-worker.js",
    "start": "node dist/api-server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.0",
    "echarts": "^5.6.0",
    "lucide-vue-next": "^0.576.0",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "sharp": "^0.33.5",
    "unique-names-generator": "^4.7.1",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "less": "^4.6.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
