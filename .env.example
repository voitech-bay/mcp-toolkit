# Supabase (get_linkedin_messages, get_senders, get_contacts – tables: LinkedinMessages, Senders, Contacts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres (SELECT-only role) for MCP: list_supabase_schema, execute_readonly_sql
# Use the pooler connection string from Supabase → Project Settings → Database (URI, sslmode=require).
# SUPABASE_READONLY_DATABASE_URL=postgresql://readonly:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# READONLY_DATABASE_URL=postgresql://...

# Source API for sync (same as main/ – GetSales-style: contacts, linkedin-messages, sender-profiles)
SOURCE_API_BASE_URL=https://api.getsales.io
SOURCE_API_KEY=your-bearer-token
# Optional fallback only. Prefer saving Team ID per project in the Sync page.
# SOURCE_TEAM_ID=12345

# Hybrid GetSales sync: webhooks stay active 24/7; reconciliation runs hourly in this local-time window.
# GETSALES_WEBHOOK_SECRET=generate-a-long-random-secret
# GETSALES_SCHEDULED_SYNC_ENABLED=true
# GETSALES_SCHEDULED_SYNC_TIMEZONE=Europe/Lisbon
# GETSALES_SCHEDULED_SYNC_START_HOUR=8
# GETSALES_SCHEDULED_SYNC_END_HOUR=20

# OpenRouter (generated message API)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENMODEL_API_KEY=your-openmodel-api-key
# FEASIBLE_OPENMODEL_MODEL=deepseek-v4-flash
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional prompt caching (Anthropic models through OpenRouter)
# OPENROUTER_PROMPT_CACHE_ENABLED=1
# OPENROUTER_PROMPT_CACHE_TTL=1h

# Apollo (search_companies, search_people)
APOLLO_API_KEY=your-apollo-api-key

# Ocean.io (search_lookalike_companies)
OCEAN_API_TOKEN=your-ocean-api-token

# InMail review: single-contact "Run new research + InMail" webhook (n8n).
# Production webhook URL of the "Sprites - InMail Single Contact [webhook]" workflow.
# N8N_INMAIL_SINGLE_WEBHOOK_URL=https://primary-production-36cb4.up.railway.app/webhook/inmail-single-xxxxxxxx

# Workflow launcher (Pipeline > Launch workflow). Each pipeline's multi-UUID webhook
# accepts { lead_uuids, projectId, launch_id }, fetches contacts by UUID inside n8n,
# and must echo launch_id onto every row it posts to /api/n8n/workflow-results.
# Base + (optional) public API key for executions enrichment:
# N8N_BASE_URL=https://primary-production-36cb4.up.railway.app
# N8N_API_KEY=your-n8n-public-api-key
# Per-pipeline webhook URLs (set once each multi-UUID workflow exists):
# N8N_RESEARCH_MULTI_WEBHOOK_URL=https://primary-production-36cb4.up.railway.app/webhook/research-multi-xxxxxxxx
# N8N_INMAIL_MULTI_WEBHOOK_URL=https://primary-production-36cb4.up.railway.app/webhook/inmail-multi-xxxxxxxx
# N8N_FOLLOWUP_MULTI_WEBHOOK_URL=https://primary-production-36cb4.up.railway.app/webhook/followup-multi-xxxxxxxx

# Feasible Phase B only (skip Phase 0) — company card "Run n8n research" button.
# N8N_FEASIBLE_PHASE_B_ONLY_WEBHOOK_URL=https://primary-production-36cb4.up.railway.app/webhook/feasible-phase-b-only-trigger
# Or set N8N_URL to the n8n instance origin (webhook path is appended automatically).
# N8N_URL=https://primary-production-36cb4.up.railway.app

# Optional: local HTTP server port
# PORT=3000

# MCP render_chart: absolute URLs for saved charts.
# Resolution order: CHARTS_PUBLIC_BASE_URL → https://$RAILWAY_PUBLIC_DOMAIN → http://localhost:$PORT.
# CHARTS_PUBLIC_BASE_URL=https://your-api.example.com
# Railway injects RAILWAY_PUBLIC_DOMAIN automatically (e.g. voitech.up.railway.app).
# RAILWAY_PUBLIC_DOMAIN=voitech.up.railway.app

# Fireflies.ai → POST /api/webhooks/fireflies (see docs/fireflies-webhooks.md)
# FIREFLIES_WEBHOOK_SECRET=signing-secret-from-fireflies-dashboard
# Optional: forward transcript-ready jobs to your Cursor agent / other repo HTTP handler
# FIREFLIES_CONTEXT_AGENT_WEBHOOK_URL=https://your-worker.example/hooks/fireflies
# FIREFLIES_CONTEXT_AGENT_WEBHOOK_BEARER=optional-shared-secret

ENRICHMENT_BATCH_WAIT_MS=30000

# Optional: route enrichment queue APIs to batch-worker SaaS service.
# When set, /api/enrichment/{enqueue,queue,runs,batch,stop,restart} use batch-worker
# and preserve legacy status semantics in responses.
# BATCH_WORKER_API_BASE_URL=http://localhost:4100
